{
  "RA if": {
    "prefix": "if",
    "body": [
      "if (${1:condition})",
      "{",
      "\t$0",
      "}"
    ],
    "description": "If statement"
  },
  "RA elif": {
    "prefix": "elif",
    "body": [
      "elif (${1:condition})",
      "{",
      "\t$0",
      "}"
    ],
    "description": "Else-if branch"
  },
  "RA ifelse": {
    "prefix": "ifelse",
    "body": [
      "if (${1:condition})",
      "{",
      "\t$2",
      "}",
      "else",
      "{",
      "\t$0",
      "}"
    ],
    "description": "If/else statement"
  },
  "RA switch": {
    "prefix": "switch",
    "body": [
      "switch (${1:value})",
      "{",
      "\tcase ${2:pattern}:",
      "\t\t$0",
      "\tdefault:",
      "\t\tpass",
      "}"
    ],
    "description": "Switch block"
  },
  "RA case": {
    "prefix": "case",
    "body": [
