{
  "scopeName": "source.ra",
  "name": "RA",
  "fileTypes": [
    "ra"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ra",
          "match": "//.*$"
        },
        {
          "name": "comment.line.hash.ra",
          "match": "#.*$"
        },
        {
          "name": "comment.line.triple-dash.ra",
          "match": "---.*$"
        },
        {
          "name": "comment.block.ra",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.block.xml.ra",
          "begin": "<!--",
          "end": "-->"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ra",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ra",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.ra",
              "begin": "\\$\\{",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.begin.ra"
                }
              },
              "end": "\\}",
              "endCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.end.ra"
                }
              },
              "patterns": [
                {
                  "include": "source.ra"
                }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.single.ra",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.ra",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.ra",
              "begin": "\\$\\{",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.begin.ra"
                }
              },
              "end": "\\}",
              "endCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.end.ra"
                }
              },
              "patterns": [
                {
                  "include": "source.ra"
                }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.backtick.ra",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "constant.character.escape.ra",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.ra",
              "begin": "\\$\\{",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.begin.ra"
                }
              },
              "end": "\\}",
              "endCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.end.ra"
                }
              },
              "patterns": [
                {
                  "include": "source.ra"
                }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.ra",
          "match": "\\b0[xX][0-9a-fA-F_]+(?:[uU]?[iIlLsS]|[fFdDmM])?\\b"
        },
        {
          "name": "constant.numeric.binary.ra",
          "match": "\\b0[bB][01_]+(?:[uU]?[iIlLsS]|[fFdDmM])?\\b"
        },
        {
          "name": "constant.numeric.octal.ra",
          "match": "\\b0[oO][0-7_]+(?:[uU]?[iIlLsS]|[fFdDmM])?\\b"
        },
        {
          "name": "constant.numeric.float.ra",
          "match": "\\b(?:\\d[\\d_]*\\.\\d[\\d_]*(?:[eE][+-]?\\d[\\d_]*)?|\\d[\\d_]*[eE][+-]?\\d[\\d_]*|\\d[\\d_]*\\.)[fFdDmM]?\\b"
        },
        {
          "name": "constant.numeric.integer.ra",
          "match": "\\b\\d[\\d_]*(?:[uU]?[iIlLsS]|[fFdDmM])?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ra",
          "match": "\\b(?:if|elif|else|and|or|not|in|as|typeof|nameof|with|to|step|times|delay|self|super|switch|case|default|try|catch|finally|retry|for|while|do|break|continue|ret|yield|goto|pass|fn|class|struct|interface|trait|enum|impl|extend|pub|abstract|override|static|var|const|final|let|del|from|import)\\b"
        },
        {
          "name": "keyword.operator.word.ra",
          "match": "\\bnot\\s+in\\b"
        },
        {
          "name": "constant.language.ra",
          "match": "\\b(?:true|false|null)\\b"
        },
        {
          "name": "storage.type.ra",
          "match": "\\b(?:int|number|long|float|double|uint|ulong|short|ushort|int128|uint128|decimal|byte|bool|string|char|void|object|any)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.ra",
          "match": "(?:\\?\\?=|\\?\\?|\\.\\.=|\\.\\.\\.|\\.\\.|::|=>|->|\\+\\+|--|\\+=|-=|\\*=|/=|%=|\\^=|&&=|\\|\\|=|<<=|>>=|===|!==|==|!=|<=|>=|<<|>>|&=|\\|=|\\^|~|!|\\+|-|\\*|/|%|=|<|>|\\?|:|\\.|,|;)"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.ra",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
